# Modulate API key — obtain from https://www.modulate-developer-apis.com/web/docs.html
# Option 1: Copy this file to .env — it is loaded automatically at startup
#   cp .env.example .env && $EDITOR .env
# Option 2: Export the variable in your shell
#   export MODULATE_API_KEY=your_api_key_here
MODULATE_API_KEY=your_api_key_here
